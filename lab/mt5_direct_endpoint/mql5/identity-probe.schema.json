{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tradejournal.local/schemas/mt5-direct-endpoint/identity-probe-v3.json",
  "title": "MT5 direct-endpoint one-shot identity evidence",
  "$comment": "The two raw terminal paths are confined to this local probe artifact. A trusted consumer hashes them and the exact artifact bytes, exports only those digests, and never copies raw paths into normalized evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "probe_version",
    "run_id",
    "generated_at_unix",
    "terminal_result",
    "expected_login_loaded",
    "terminal_connected",
    "account_match",
    "account_server",
    "account_company",
    "account_trade_mode",
    "account_trade_allowed",
    "account_trade_expert",
    "terminal_trade_allowed",
    "terminal_build",
    "terminal_path",
    "terminal_data_path"
  ],
  "properties": {
    "schema_version": {
      "const": 3
    },
    "probe_version": {
      "const": "3.0.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "generated_at_unix": {
      "type": "integer",
      "minimum": 0
    },
    "terminal_result": {
      "enum": [
        "CONNECTED_IDENTITY_AVAILABLE",
        "IDENTITY_MISMATCH",
        "TIMEOUT",
        "NOT_CONNECTED",
        "INPUT_INVALID",
        "OUTPUT_FAILURE"
      ]
    },
    "expected_login_loaded": {
      "type": "boolean"
    },
    "terminal_connected": {
      "type": "boolean"
    },
    "account_match": {
      "type": "boolean"
    },
    "account_server": {
      "type": "string"
    },
    "account_company": {
      "type": "string"
    },
    "account_trade_mode": {
      "enum": ["DEMO", "CONTEST", "REAL", "UNKNOWN"]
    },
    "account_trade_allowed": {
      "type": "boolean"
    },
    "account_trade_expert": {
      "type": "boolean"
    },
    "terminal_trade_allowed": {
      "type": "boolean"
    },
    "terminal_build": {
      "type": "integer",
      "minimum": 0
    },
    "terminal_path": {
      "type": "string"
    },
    "terminal_data_path": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "terminal_result": {
            "enum": [
              "CONNECTED_IDENTITY_AVAILABLE",
              "IDENTITY_MISMATCH",
              "TIMEOUT",
              "NOT_CONNECTED"
            ]
          }
        },
        "required": ["terminal_result"]
      },
      "then": {
        "properties": {
          "expected_login_loaded": {"const": true},
          "run_id": {
            "not": {"const": "00000000-0000-4000-8000-000000000000"}
          },
          "terminal_build": {"minimum": 1},
          "terminal_path": {"minLength": 1},
          "terminal_data_path": {"minLength": 1}
        }
      }
    },
    {
      "if": {
        "properties": {
          "terminal_result": {"const": "CONNECTED_IDENTITY_AVAILABLE"}
        },
        "required": ["terminal_result"]
      },
      "then": {
        "properties": {
          "terminal_connected": {"const": true},
          "account_match": {"const": true},
          "account_server": {"minLength": 1},
          "account_company": {"minLength": 1},
          "account_trade_mode": {"enum": ["DEMO", "CONTEST", "REAL"]}
        }
      }
    },
    {
      "if": {
        "properties": {
          "terminal_result": {"const": "IDENTITY_MISMATCH"}
        },
        "required": ["terminal_result"]
      },
      "then": {
        "properties": {
          "terminal_connected": {"const": true},
          "account_match": {"const": false},
          "account_server": {"minLength": 1},
          "account_company": {"minLength": 1},
          "account_trade_mode": {"enum": ["DEMO", "CONTEST", "REAL"]}
        }
      }
    },
    {
      "if": {
        "properties": {
          "terminal_result": {"const": "TIMEOUT"}
        },
        "required": ["terminal_result"]
      },
      "then": {
        "properties": {
          "terminal_connected": {"const": true},
          "account_match": {"const": false}
        }
      }
    },
    {
      "if": {
        "properties": {
          "terminal_result": {"const": "NOT_CONNECTED"}
        },
        "required": ["terminal_result"]
      },
      "then": {
        "properties": {
          "terminal_connected": {"const": false},
          "account_match": {"const": false},
          "account_server": {"const": ""},
          "account_company": {"const": ""},
          "account_trade_mode": {"const": "UNKNOWN"},
          "account_trade_allowed": {"const": false},
          "account_trade_expert": {"const": false}
        }
      }
    }
  ]
}
