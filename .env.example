# Copiare in .env e personalizzare. .env NON va mai versionato (vedi .gitignore).
# Nessun valore reale e' presente in questo file di esempio.

# true = usa mock_mt5_client.py (nessuna dipendenza da Wine/MT5). false = usa mt5_client.py
# reale (richiede un terminale MT5 raggiungibile via Wine, vedi README "Fase 2: MT5 reale +
# Wine" -- testabile solo su una VPS Ubuntu amd64, non su questo POC macOS).
MOCK_MODE=true

# true = gli eventi vengono stampati (sanitizzati) invece di essere inviati via HTTP.
DRY_RUN=true

# Credenziali dell'account MT5 (necessarie solo con MOCK_MODE=false). Lasciare vuoto per il
# test mock: non inserire mai credenziali reali in questo repository.
#
# IMPORTANTE (sicurezza): MT5_PASSWORD deve essere la password INVESTOR (sola lettura)
# dell'account, MAI la password di trading/principale. Questo worker legge soltanto
# account_info/posizioni/ordini/deal e non ha alcun bisogno di poter operare sull'account -- una
# password investor limita il danno anche in caso di fuga di credenziali.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Endpoint di ingestion di TradeJournal e relativo bridge token (Impostazioni -> Trading
# Accounts nell'app principale). Lasciare vuoto per restare in solo DRY_RUN.
TRADEJOURNAL_API_URL=
TRADEJOURNAL_BRIDGE_TOKEN=

# Intervallo di poll, in secondi.
POLL_INTERVAL_SECONDS=5

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
