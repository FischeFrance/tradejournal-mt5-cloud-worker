# Copiare in .env e personalizzare. .env NON va mai versionato (vedi .gitignore).
# Nessun valore reale e' presente in questo file di esempio.

# true = usa mock_mt5_client.py (nessuna dipendenza da Wine/MT5). false = usa mt5_client.py
# reale (richiede un terminale MT5 raggiungibile via Wine, vedi README "Fase 2: MT5 reale +
# Wine" -- testabile solo su una VPS Ubuntu amd64, non su questo POC macOS).
MOCK_MODE=true

# true = gli eventi vengono stampati (sanitizzati) invece di essere inviati via HTTP.
DRY_RUN=true

# Credenziali dell'account MT5 (necessarie solo con MOCK_MODE=false). Lasciare vuoto per il
# test mock: non inserire mai credenziali reali in questo repository.
#
# IMPORTANTE (sicurezza): MT5_PASSWORD deve essere la password INVESTOR (sola lettura)
# dell'account, MAI la password di trading/principale. Questo worker legge soltanto
# account_info/posizioni/ordini/deal e non ha alcun bisogno di poter operare sull'account -- una
# password investor limita il danno anche in caso di fuga di credenziali.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Endpoint di ingestion di TradeJournal e relativo bridge token (Impostazioni -> Trading
# Accounts nell'app principale). Lasciare vuoto per restare in solo DRY_RUN.
TRADEJOURNAL_API_URL=
TRADEJOURNAL_BRIDGE_TOKEN=

# Intervallo di poll, in secondi.
POLL_INTERVAL_SECONDS=5

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ============================================================================
# Modalita' research (opzionale, disattiva di default). Riguarda ESCLUSIVAMENTE il
# market-data-worker (worker/market_data_main.py, processo/container separato dal trade-sync
# worker sopra): non cambia in alcun modo la sincronizzazione dei trade verso TradeJournal.
# Vedi README, sezione "Modalita' research (dati di mercato)", e docker-compose.research.yml.
#
# IMPORTANTE (installazioni cliente): lasciare questa sezione cosi' com'e' (client/false). Il
# market-data-worker e Postgres non vengono avviati a meno di aggiungere esplicitamente
# `-f docker-compose.research.yml` al comando docker compose: non basta un valore diverso qui
# dentro se quel file non viene incluso, ma tenere i default e' comunque la scelta piu' sicura.
# ============================================================================

# client = comportamento attuale (default, invariato). research = abilita il market-data-worker
# (solo se combinato con ENABLE_MARKET_DATA=true). Nessun altro valore e' accettato.
APP_MODE=client

# true richiede APP_MODE=research: il worker si rifiuta di avviarsi altrimenti (fail fast).
ENABLE_MARKET_DATA=false

# Connessione al Postgres locale della modalita' research (mai un database remoto/Supabase in
# questa fase). Con docker-compose.research.yml e' costruita automaticamente dal servizio
# market-data-worker a partire da POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB piu' sotto: non va
# impostata a mano in quel caso. Necessaria solo per eseguire market_data_main.py fuori da Docker.
DATABASE_URL=

# Simboli e timeframe da raccogliere in modalita' research, separati da virgola.
MARKET_SYMBOLS=EURUSD
MARKET_TIMEFRAMES=M1,M5,M15,H1,H4,D1

# Intervallo di poll del market-data-worker, in secondi (indipendente da POLL_INTERVAL_SECONDS,
# che resta solo del trade-sync worker).
MARKET_DATA_POLL_SECONDS=60

# mock = sorgente deterministica in-process, nessuna dipendenza da Wine/MT5/rete. mt5 = client
# HTTP verso mt5-bridge (fake per i test locali, reale in futuro su una VPS AMD64 -- vedi README,
# "mt5-bridge"). Il market-data-worker Linux non importa MAI il pacchetto MetaTrader5 ne' apre
# connessioni Wine/IPC direttamente, in nessuno dei due casi: parla solo HTTP con un servizio
# separato (vedi worker/market_data_source.py:Mt5MarketDataSource).
MARKET_DATA_SOURCE=mock

# Credenziali del Postgres locale avviato da docker-compose.research.yml (servizio "postgres").
# Nessun default per POSTGRES_PASSWORD: `docker compose config`/`up` falliscono subito se non
# viene impostata qui, invece di avviare un database con una password debole o nota. Credenziali
# locali alla macchina Ubuntu di destinazione, non legate a nessun account reale/Supabase.
POSTGRES_DB=tradejournal_research
POSTGRES_USER=research
POSTGRES_PASSWORD=

# ============================================================================
# mt5-bridge (rilevante solo con MARKET_DATA_SOURCE=mt5). Il market-data-worker parla con questo
# servizio via HTTP: non importa mai MetaTrader5 ne' apre connessioni Wine/IPC direttamente (vedi
# README, "Perche' il Python Linux del market-data-worker non importa MetaTrader5").
#
# Per i test locali (qualunque architettura, incluso Ubuntu ARM64), il bridge e' bridge/fake/
# fake_bridge.py, avviato da docker-compose.research-mt5-fake.yml come servizio mt5-bridge-fake:
# nessuna dipendenza da Wine/MT5, dati sintetici deterministici. Il bridge REALE
# (bridge/windows/mt5_bridge.py) e' predisposto ma NON VALIDATO in questa fase: richiede Windows
# Python sotto Wine su una VPS Ubuntu AMD64 con un vero terminale MT5, non ancora impacchettato
# in un servizio Docker (vedi README).
# ============================================================================

# URL del bridge HTTP. Con docker-compose.research-mt5-fake.yml il default e' gia'
# http://mt5-bridge-fake:8080 (non serve impostarlo qui per i test locali).
MT5_BRIDGE_URL=

# Token condiviso tra market-data-worker e il bridge (fake o reale): stesso valore su entrambi i
# lati, mai versionato. Obbligatorio per avviare mt5-bridge-fake (nessun default: `docker compose
# config`/`up` falliscono subito se mancante, stesso principio di POSTGRES_PASSWORD sopra).
MT5_BRIDGE_TOKEN=

MT5_BRIDGE_TIMEOUT_SECONDS=10

# Simbolo effettivo su cui il bridge deve interrogare MT5 (puo' differire dal nome canonico
# EURUSD usato in TradeJournal/Postgres, es. "EURUSD.a" per alcuni broker). Il fake bridge di
# test accetta come simbolo valido solo questo stesso valore.
EURUSD_BROKER_SYMBOL=EURUSD

# ============================================================================
# Credenziali del bridge MT5 REALE (bridge/windows/mt5_bridge.py). Lette SOLO da quel servizio,
# MAI dal market-data-worker: worker/config.py non conosce affatto queste variabili (usa solo
# MT5_BRIDGE_URL/TOKEN sopra). Rilevanti solo quando (in futuro, su una VPS AMD64) si avvia il
# bridge reale, non per il fake bridge (che non ha bisogno di nessuna di queste).
#
# Riusa MT5_LOGIN/MT5_PASSWORD/MT5_SERVER gia' dichiarate piu' sopra per il trade-sync worker
# (stesso account MT5, stesse regole di sicurezza): quando si avvia mt5-bridge reale, vanno
# impostate nell'ambiente DI QUEL servizio, mai in quello di market-data-worker.
#
# IMPORTANTE (sicurezza): MT5_PASSWORD deve essere la password INVESTOR (sola lettura), MAI
# quella di trading. Il bridge e' di sola lettura (account_info + candele storiche): nessun
# endpoint di trading esiste (vedi bridge/windows/mt5_bridge.py e README).
#
# Percorso del terminale MT5 (terminal64.exe) dentro il WINEPREFIX condiviso col bridge.
MT5_TERMINAL_PATH=
