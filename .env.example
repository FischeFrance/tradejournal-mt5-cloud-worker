# Copiare in .env e personalizzare. .env NON va mai versionato (vedi .gitignore).
# Nessun valore reale e' presente in questo file di esempio.

# Alias di configurazione ancora supportato: se MT5_CLIENT_SOURCE e' vuoto, true seleziona il
# mock in-process e false seleziona il nuovo default bridge HTTP. Il client diretto MetaTrader5
# sotto Python Linux non e' il runtime raccomandato.
MOCK_MODE=true

# Sorgente del trade-sync worker:
#   mock   = scenario in-process, nessuna rete/MT5;
#   bridge = GET /health + POST /v1/trading/snapshot sul servizio mt5-bridge;
#   direct = client MetaTrader5 legacy, predisposto ma non validato end-to-end.
# Lasciare vuoto per conservare la derivazione retrocompatibile da MOCK_MODE descritta sopra.
# docker-compose.trade-sync-fake.yml forza sempre bridge.
MT5_CLIENT_SOURCE=

# true = gli eventi vengono stampati (sanitizzati) invece di essere inviati via HTTP.
DRY_RUN=true

# Credenziali dell'account MT5. In modalita' bridge appartengono ESCLUSIVAMENTE al runtime
# per-account (deploy/instance: usate solo per generare lo startup.ini del terminale, mai lette
# da alcun processo Python); il worker Linux riceve soltanto MT5_BRIDGE_URL/TOKEN. Sono lette
# direttamente dal worker solo nel percorso legacy MT5_CLIENT_SOURCE=direct. Lasciare vuoto per
# fake/mock; non inserire mai credenziali reali in questo repository.
#
# IMPORTANTE (sicurezza): MT5_PASSWORD deve essere la password INVESTOR (sola lettura)
# dell'account, MAI la password di trading/principale. Questo worker legge soltanto
# account_info/posizioni/ordini/deal e non ha alcun bisogno di poter operare sull'account -- una
# password investor limita il danno anche in caso di fuga di credenziali.
MT5_LOGIN=
MT5_PASSWORD=
# Alternativa production a MT5_PASSWORD. Non esportare entrambe le variabili, nemmeno vuote.
# MT5_PASSWORD_FILE=/run/secrets/mt5_password
MT5_SERVER=

# Endpoint di ingestion di TradeJournal e relativo token (Impostazioni -> Trading Accounts
# nell'app principale). TRADEJOURNAL_BRIDGE_TOKEN autentica worker -> app e DEVE essere diverso
# da MT5_BRIDGE_TOKEN, che autentica worker -> mt5-bridge. Lasciare vuoto solo fuori dal compose
# trade-sync dedicato e quando si resta in DRY_RUN.
TRADEJOURNAL_API_URL=
TRADEJOURNAL_BRIDGE_TOKEN=
# Alternativa production; conflitto fail-fast con TRADEJOURNAL_BRIDGE_TOKEN.
# TRADEJOURNAL_BRIDGE_TOKEN_FILE=/run/secrets/tradejournal_bridge_token

# Intervallo di poll, in secondi.
POLL_INTERVAL_SECONDS=5

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ============================================================================
# Modalita' research (opzionale, disattiva di default). Riguarda ESCLUSIVAMENTE il
# market-data-worker (worker/market_data_main.py, processo/container separato dal trade-sync
# worker sopra): non cambia in alcun modo la sincronizzazione dei trade verso TradeJournal.
# Vedi README, sezione "Modalita' research (dati di mercato)", e docker-compose.research.yml.
#
# IMPORTANTE (installazioni cliente): lasciare questa sezione cosi' com'e' (client/false). Il
# market-data-worker e Postgres non vengono avviati a meno di aggiungere esplicitamente
# `-f docker-compose.research.yml` al comando docker compose: non basta un valore diverso qui
# dentro se quel file non viene incluso, ma tenere i default e' comunque la scelta piu' sicura.
# ============================================================================

# client = comportamento attuale (default, invariato). research = abilita il market-data-worker
# (solo se combinato con ENABLE_MARKET_DATA=true). Nessun altro valore e' accettato.
APP_MODE=client

# true richiede APP_MODE=research: il worker si rifiuta di avviarsi altrimenti (fail fast).
ENABLE_MARKET_DATA=false

# Connessione al Postgres locale della modalita' research (mai un database remoto/Supabase in
# questa fase). Con docker-compose.research.yml e' costruita automaticamente dal servizio
# market-data-worker a partire da POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB piu' sotto: non va
# impostata a mano in quel caso. Necessaria solo per eseguire market_data_main.py fuori da Docker.
DATABASE_URL=

# Simboli e timeframe da raccogliere in modalita' research, separati da virgola.
MARKET_SYMBOLS=EURUSD
MARKET_TIMEFRAMES=M1,M5,M15,H1,H4,D1

# Intervallo di poll del market-data-worker, in secondi (indipendente da POLL_INTERVAL_SECONDS,
# che resta solo del trade-sync worker).
MARKET_DATA_POLL_SECONDS=60

# mock = sorgente deterministica in-process, nessuna dipendenza da Wine/MT5/rete. mt5 = client
# HTTP verso mt5-bridge (fake per i test sintetici, reale su macOS/VPS AMD64 -- vedi README,
# "mt5-bridge"). Il market-data-worker Linux non importa MAI il pacchetto MetaTrader5 ne' apre
# connessioni Wine/IPC direttamente, in nessuno dei due casi: parla solo HTTP con un servizio
# separato (vedi worker/market_data_source.py:Mt5MarketDataSource).
MARKET_DATA_SOURCE=mock

# Credenziali del Postgres locale avviato da docker-compose.research.yml (servizio "postgres").
# Nessun default per POSTGRES_PASSWORD: `docker compose config`/`up` falliscono subito se non
# viene impostata qui, invece di avviare un database con una password debole o nota. Credenziali
# locali alla macchina Ubuntu di destinazione, non legate a nessun account reale/Supabase.
POSTGRES_DB=tradejournal_research
POSTGRES_USER=research
POSTGRES_PASSWORD=

# ============================================================================
# mt5-bridge (rilevante con MT5_CLIENT_SOURCE=bridge e/o MARKET_DATA_SOURCE=mt5). Entrambi i
# worker Linux parlano con questo servizio via HTTP: non importano mai MetaTrader5 ne' aprono
# connessioni Wine/IPC direttamente (vedi README, "mt5-bridge").
#
# Per i test locali (qualunque architettura, incluso Ubuntu ARM64), il bridge e' bridge/fake/
# fake_bridge.py, avviato da docker-compose.trade-sync-fake.yml per il trade-sync o da
# docker-compose.research-mt5-fake.yml per le candele: nessuna dipendenza da Wine/MT5, dati
# sintetici deterministici. Il bridge REALE e' ora un Expert Advisor MQL5 read-only
# (mt5/experts/TradeJournalBridge.mq5) che scrive file JSON letti da un processo Linux stdlib
# (bridge/files/file_bridge.py, nessun Python Windows/pacchetto MetaTrader5 coinvolto); e'
# impacchettato dal runtime per-account in deploy/instance con il golden template esterno.
# ============================================================================

# URL del bridge HTTP. Nei compose fake il default e' gia' http://mt5-bridge-fake:8080; nel
# runtime per-account e' sempre http://mt5-runtime:8090, raggiungibile soltanto sulla rete
# Docker interna (nessuna porta pubblicata sull'host).
MT5_BRIDGE_URL=

# Token privato condiviso tra worker Linux e bridge (fake o reale): stesso valore sui due lati,
# mai versionato e sempre diverso da TRADEJOURNAL_BRIDGE_TOKEN. Obbligatorio per i compose fake.
MT5_BRIDGE_TOKEN=
# Alternativa production; conflitto fail-fast con MT5_BRIDGE_TOKEN.
# MT5_BRIDGE_TOKEN_FILE=/run/secrets/mt5_bridge_token

MT5_BRIDGE_TIMEOUT_SECONDS=10

# Finestra UTC dei deal di uscita inclusi in /v1/trading/snapshot. Valori validi 1..168 ore.
MT5_DEAL_LOOKBACK_HOURS=24

# Nome esatto del simbolo broker inviato a POST /v1/candles (puo' differire dal canonico EURUSD
# usato in TradeJournal/Postgres, es. "EURUSD.a"). Nel runtime reale e' anche il simbolo su cui
# l'entrypoint aggancia l'Expert Advisor (Symbol= in startup.ini, vedi
# deploy/instance/entrypoint-runtime.sh): un solo valore per entrambi gli usi. Nessun suffisso o
# alias viene aggiunto automaticamente. Il fake accetta solo questo stesso valore.
EURUSD_BROKER_SYMBOL=EURUSD

# ============================================================================
# Configurazione del runtime MT5 REALE (deploy/instance: EA MQL5 + bridge/files/file_bridge.py).
# Letta SOLO dall'entrypoint del container mt5-runtime, MAI dal trade-sync worker o dal
# market-data-worker, che usano soltanto MT5_BRIDGE_URL/TOKEN.

# Percorso Windows di terminal64.exe nel WINEPREFIX del golden template. Usato dall'entrypoint
# sia per avviare il terminale sia per derivare (nella stessa cartella d'installazione) il
# sandbox file dell'EA e il percorso del TradeJournalBridge.ex5 compilato.
MT5_TERMINAL_PATH=

# Eta' massima ammessa dell'ultimo heartbeat.json dell'EA prima che GET /health del bridge
# Linux riporti "degraded" (secondi). Aumentare solo se InpTimerSeconds nell'EA e' stato
# aumentato oltre il default di 2s.
MT5_HEARTBEAT_MAX_AGE_SECONDS=15

# Identificativo di connessione, non sensibile (UUID), letto dall'EA da un file scritto
# dall'entrypoint (MQL5 non ha accesso alle variabili d'ambiente del container). Incluso in ogni
# event_id per garantire unicita' anche fra account/connessioni diverse con ticket coincidenti.
TJ_CONNECTION_ID=

# Verifica OBBLIGATORIA dell'identita' dell'account: devono coincidere esattamente con
# login/server che l'EA scrive in account.json (stessi valori di MT5_LOGIN/MT5_SERVER sopra,
# sotto nomi distinti perche' li legge un processo diverso: il bridge Linux, non l'entrypoint).
# Se non coincidono, /health riporta "degraded" e /v1/trading/snapshot rifiuta di rispondere:
# nessun dato viene mai attribuito silenziosamente a una connessione diversa da quella prevista.
TJ_EXPECTED_MT5_LOGIN=
TJ_EXPECTED_MT5_SERVER=

# Bind del server HTTP del bridge reale. Pubblicare 0.0.0.0 soltanto su una rete privata e con
# firewall; MT5_BRIDGE_TOKEN resta sempre obbligatorio.
HOST=0.0.0.0
PORT=8080

# ============================================================================
# Provisioning agent host-side (VPS, disattivo finche' non avviato esplicitamente).
# Nessuno di questi valori e' un secret. Password/token vivono esclusivamente in file 0400/0600
# sotto TJ_SECRETS_ROOT/<connection_id>/ e non devono comparire qui o nei job JSON.
# ============================================================================
TJ_PROVISIONING_ROOT=/opt/tradejournal
# Checkout usato come build context. Il default e' la root del repository corrente.
TJ_PROVISIONING_REPOSITORY_ROOT=/opt/tradejournal/tradejournal-mt5-cloud-worker
TJ_INSTANCES_ROOT=/opt/tradejournal/instances
TJ_STATE_ROOT=/opt/tradejournal/state
TJ_LOCKS_ROOT=/opt/tradejournal/locks
TJ_SECRETS_ROOT=/opt/tradejournal/secrets
TJ_QUEUE_ROOT=/opt/tradejournal/queue
TJ_COMPOSE_TEMPLATE=/opt/tradejournal/tradejournal-mt5-cloud-worker/deploy/instance/compose.yaml
MT5_TEMPLATE_ARCHIVE=/opt/tradejournal/templates/mt5-prefix.tar.zst
MT5_TEMPLATE_SHA256=
# real usa il golden template; mock usa il fake bridge e non richiede Wine/MT5.
MT5_RUNTIME_TARGET=real
# I secret file-backed devono appartenere all'UID fisso 1000 dei container. Il provisioner
# rifiuta valori diversi per evitare mount illeggibili (vedi docs/provisioning.md).
TJ_SECRET_OWNER_UID=1000
TJ_ALLOW_INSECURE_HTTP=false
TJ_FILESYSTEM_POLL_SECONDS=2
TJ_DOCKER_TIMEOUT_SECONDS=300
TJ_RUNTIME_CPUS=1.50
TJ_RUNTIME_MEM_LIMIT=3g
TJ_WORKER_CPUS=0.50
TJ_WORKER_MEM_LIMIT=512m
# In dry-run gli eventi restano nell'outbox e non vengono persi. Dopo aver impostato false,
# riavviare l'agent e inviare un nuovo job provision con nuovo job_id per rigenerare instance.env
# e consegnare anche gli eventi accumulati; start/restart da soli non aggiornano questa opzione.
TJ_WORKER_DRY_RUN=true

# ============================================================================
# Windows Agent control plane (windows_agent.runtime_config) -- separato dal legacy
# trade-sync worker Linux/Docker sopra. Consumato da windows_agent/runtime_config.py.
# Il bearer token dell'Agent NON e' una variabile d'ambiente: vive solo in DPAPI, scritto da
# scripts/windows/receive-agent-token.ps1 (vedi contracts/mt5-agent-v1/README.md e
# handoff/STAGING-SETUP.txt per il runbook completo). Non impostare mai qui un token reale.
# ============================================================================
# URL completo della Edge Function trading-agent, es. https://<staging-project-ref>.functions.supabase.co/trading-agent
# HTTPS obbligatorio salvo localhost/127.0.0.1 (vedi windows_agent/api_client.py).
TRADEJOURNAL_API_URL=
# Intervallo di polling tra un claim e il successivo quando non ci sono job disponibili.
TRADEJOURNAL_POLL_SECONDS=5
# Root DPAPI per agent_token/mt5_provisioning_key; lasciare vuoto per il default C:\TradeJournal\secrets.
TRADEJOURNAL_SECRETS_ROOT=
TJ_WORKER_POLL_SECONDS=5
